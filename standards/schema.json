{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-governance-assessor.local/standards/controls.schema.json",
  "title": "ControlsFile",
  "type": "object",
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "questionType": {
      "type": "string",
      "enum": ["yes_no", "scale", "text"]
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "informational"]
    },
    "control": {
      "type": "object",
      "required": ["control_id", "title", "question_type"],
      "properties": {
        "control_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-]+$"
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "question_type": { "$ref": "#/$defs/questionType" },
        "weight": { "type": "integer", "minimum": 0, "maximum": 10 },
        "required": { "type": "boolean" },
        "guidance": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": { "$ref": "#/$defs/severity" },
        "sort_order": { "type": "integer" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "question_type": { "const": "scale" } }
          },
          "then": {
            "required": ["options"],
            "properties": {
              "options": { "type": "array", "minItems": 1 }
            }
          }
        }
      ]
    },
    "section": {
      "type": "object",
      "required": ["id", "title", "description", "controls"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "controls": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/control" }
        }
      }
    }
  }
}
